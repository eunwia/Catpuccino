
@{
    ViewData["Title"] = "Onboarding";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cattpuccino</title>
    <link href="https://fonts.googleapis.com/css2?family=Jua&display=swap" rel="stylesheet" />
    <link href="~/css/onboarding.css" rel="stylesheet" />
</head>
<body>

    <div class="brand-title"><img src="~/images/adminpics/catpuccino-logo.png" alt="Catpuccino Logo" /></div>
    <div class="cards-row">

        <a asp-controller="Admin" asp-action="Login" class="role-card">
            <img src="~/images/adminpics/cat-admin.png" alt="Admin cat with laptop" />
            <div class="role-btn">Login as Admin</div>
        </a>

        <a asp-controller="User" asp-action="Login" class="role-card">
            <img src="~/images/adminpics/cat-user.png" alt="User cat with coffee" />
            <div class="role-btn">Login as User</div>
        </a>

    </div>

</body>
</html>
