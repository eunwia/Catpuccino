@using System.Linq
@model IEnumerable<Catpuccino_FinalProject.Models.Product>

@{
    ViewData["Title"] = "Menus";
}

<link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />

<header class="menu-hero">
    <div class="container d-flex justify-content-between align-items-center">
        <h1 class="menu-title">Our Menu</h1>

        <div class="position-relative">
            <button class="btn btn-order-main" data-bs-toggle="modal" data-bs-target="#orderModal">
                Order <span class="notification-dot"></span>
            </button>
        </div>
    </div>
</header>

<div class="container text-center mt-5">
    <div class="search-container">
        <input type="text" class="form-control search-input" placeholder="Search drinks, pastries, snacks">
    </div>

    <div class="d-flex justify-content-center flex-wrap mb-5">
        <button class="filter-btn">All Items</button>
        <button class="filter-btn active">Coffee</button>
        <button class="filter-btn">Tea</button>
        <button class="filter-btn">Pastries</button>
        <button class="filter-btn">Cakes</button>
    </div>
</div>

<main class="container mb-5">
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                   
                    <div class="card menu-card h-100" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#modal-@item.Id">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 220px; object-fit: cover;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-brown fw-bold">@item.Name</h5>
                            <p class="card-text small text-muted flex-grow-1">@item.Description</p>
                            <p class="fw-bold text-brown mb-0 fs-5">P @item.Price.ToString("0")</p>
                        </div>
                    </div>
                </div>

              
                <div class="modal fade" id="modal-@item.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content modal-content-custom shadow-lg p-0">
                            
                            <img src="@item.ImageUrl" class="w-100" style="height: 250px; object-fit: cover; border-top-left-radius: 30px; border-top-right-radius: 30px;" />
                            
                            <div class="p-4">
                                <h3 class="text-brown fw-bold mb-1">@item.Name</h3>
                                <p class="small text-muted mb-4">@item.Description</p>

                              
                                <form asp-action="AddToCart" asp-controller="Order" method="post">
                                    <input type="hidden" name="ProductId" value="@item.Id" />
                                    
                                    <h5 class="text-brown fw-bold mb-3">Size</h5>
                                    
                                  
                                    <div class="d-flex gap-2 mb-4 size-selector-group">
                                        <input type="radio" id="small-@item.Id" name="Size" value="Small" class="d-none size-radio" data-addon="0" checked>
                                        <label for="small-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Small</span>
                                            <span class="small">Base</span>
                                        </label>

                                        <input type="radio" id="medium-@item.Id" name="Size" value="Medium" class="d-none size-radio" data-addon="20">
                                        <label for="medium-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Medium</span>
                                            <span class="small">+P20</span>
                                        </label>
                                        
                                        <input type="radio" id="large-@item.Id" name="Size" value="Large" class="d-none size-radio" data-addon="40">
                                        <label for="large-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Large</span>
                                            <span class="small">+P40</span>
                                        </label>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-end mb-4">
                                        <div>
                                            <h5 class="text-brown fw-bold mb-2">Quantity</h5>
                                      
                                            <div class="d-flex align-items-center gap-3">
                                                <button type="button" class="btn-qty minus-btn" data-target="@item.Id">-</button>
                                                
                                                <input type="hidden" name="Quantity" id="qty-input-@item.Id" value="1" />
                                                <span id="qty-text-@item.Id" class="fs-4 fw-bold text-brown">1</span>
                                                <button type="button" class="btn-qty plus-btn" data-target="@item.Id">+</button>
                                            </div>
                                        </div>
                                        <div>
                                          
                                            <span class="fs-5 fw-bold text-brown">Total : P<span class="live-total" id="total-@item.Id" data-baseprice="@item.Price">@item.Price.ToString("0")</span></span>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-3 mt-2">
                                        <button type="button" class="btn btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-add-to-order flex-grow-1">Add to Order</button>
                                    </div>
                                </form>
                            </div>
                            
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center empty-state">
            <img src="~/images/menupics/waitorderillus.png" style="width: 500px;" class="mb-3" />
            <h4 class="text-muted mt-3">No items currently available.</h4>
        </div>
    }
</main>

<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom shadow-lg">

            <div class="modal-header modal-header-custom border-0 d-flex justify-content-between">
                <h5 class="modal-title modal-title-custom">Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">
                <div id="cartItemsContainer">
                    <p class="text-center text-muted py-5 italic">Your cart is currently empty.</p>
                </div>

                <div class="order-totals">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-brown">Subtotal</span>
                        <span class="text-brown">P0</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold fs-4">
                        <span>Total</span>
                        <span>P0</span>
                    </div>
                </div>

                <button class="btn btn-place-order shadow-sm">Place Order</button>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Handle Quantity Plus/Minus
        document.querySelectorAll('.btn-qty').forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.getAttribute('data-target');
                const inputEl = document.getElementById('qty-input-' + targetId);
                const textEl = document.getElementById('qty-text-' + targetId);
                let currentVal = parseInt(inputEl.value);

                if (this.classList.contains('minus-btn') && currentVal > 1) {
                    currentVal--;
                } else if (this.classList.contains('plus-btn')) {
                    currentVal++;
                }

                inputEl.value = currentVal;
                textEl.textContent = currentVal;
                updateTotal(targetId);
            });
        });

        // Handle Size Selection changes
        document.querySelectorAll('.size-radio').forEach(radio => {
            radio.addEventListener('change', function() {
                const targetId = this.id.split('-')[1]; // Extracts the item.Id
                updateTotal(targetId);
            });
        });

        // Calculate the Live Total
        function updateTotal(itemId) {
            const qty = parseInt(document.getElementById('qty-input-' + itemId).value);
            const basePrice = parseFloat(document.getElementById('total-' + itemId).getAttribute('data-baseprice'));
            
            let addon = 0;
            // Find which size radio is currently checked for this specific product
            const selectedRadio = document.querySelector(`input[name="Size"][id$="-${itemId}"]:checked`);
            if (selectedRadio) {
                addon = parseFloat(selectedRadio.getAttribute('data-addon'));
            }

            const total = (basePrice + addon) * qty;
            document.getElementById('total-' + itemId).textContent = total;
        }
    });
</script>