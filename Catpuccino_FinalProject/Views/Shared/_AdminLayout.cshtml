@{
    var current = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cattpuccino Admin — @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Jua&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Jua', sans-serif;
            background-color: #FFF7F0;
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background-color: #80512F;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }

            .sidebar-brand img {
                width: 52px;
                height: 52px;
                border-radius: 14px;
                object-fit: cover;
            }

        .sidebar-brand-text strong {
            display: block;
            font-size: 1.3rem;
            color: #fff;
        }

        .sidebar-brand-text span {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.7);
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1.5rem 0;
        }

        .nav-section-label {
            font-size: 0.65rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            padding: 0.5rem 1.5rem 0.25rem;
            margin-top: 0.75rem;
        }

        .nav-link-item {
            display: block;
            padding: 0.5rem 3rem;
            color: rgba(255,255,255,0.85);
            font-size: 1.1rem;
            text-decoration: none;
            border-radius: 0;
            transition: background 0.15s, color 0.15s;
        }

            .nav-link-item:hover {
                background: rgba(255,255,255,0.12);
                color: #fff;
            }

            .nav-link-item.active {
                background: rgba(255,255,255,0.20);
                color: #fff;
            }

        .sidebar-footer {
            padding: 1.25rem 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

            .sidebar-footer .avatar {
                width: 48px;
                height: 48px;
                border-radius: 50%;
                background: #86624C;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #CCB6A1;
                font-size: 3.2rem;
                flex-shrink: 0;
            }

            .sidebar-footer .admin-name {
                color: #fff;
                font-size: 0.95rem;
                line-height: 1.2;
            }

            .sidebar-footer .admin-role {
                color: rgba(255,255,255,0.6);
                font-size: 0.72rem;
            }

        /* ── MAIN CONTENT ── */
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 0;
        }

        .page-header {
            padding: 1.5rem 2.5rem 1rem;
            border-bottom: 2px solid #80512F;
        }

            .page-header h1 {
                font-size: 2rem;
                color: #80512F;
            }

        .page-body {
            padding: 2rem 2.5rem;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="~/images/adminpics/cat-logo-dashboard.png" alt="Cattpuccino Logo" />
            <div class="sidebar-brand-text">
                <strong>Cattpuccino</strong>
                <span>Admin Panel</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a asp-controller="Admin" asp-action="Dashboard"
               class="nav-link-item @(current == "Dashboard" ? "active" : "")">
                Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Orders"
               class="nav-link-item @(current == "Orders" ? "active" : "")">
                Orders
            </a>

            <div class="nav-section-label">Catalog</div>
            <a asp-controller="Admin" asp-action="Products"
               class="nav-link-item @(current == "Products" ? "active" : "")">
                Products
            </a>

            <div class="nav-section-label">Account</div>
            <a asp-controller="Admin" asp-action="Logout"
               class="nav-link-item">
                Log out
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="avatar"><i class="fa-solid fa-circle-user"></i></div>
            <div>
                <div class="admin-name">Admin</div>
                <div class="admin-role">Cattpuccino Staff</div>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main-content">
        <div class="page-header">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="page-body">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

